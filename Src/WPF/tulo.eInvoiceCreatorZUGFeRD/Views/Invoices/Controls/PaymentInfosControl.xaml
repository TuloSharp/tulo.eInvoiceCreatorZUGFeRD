<UserControl x:Class="tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.Controls.PaymentInfosControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.Controls"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:system="clr-namespace:System;assembly=netstandard"
             xmlns:converters="clr-namespace:tulo.ResourcesWpfLib.Converters;assembly=tulo.ResourcesWpfLib"
             xmlns:placeholder="clr-namespace:tulo.PlaceholderTextBoxControl;assembly=tulo.PlaceholderTextBoxControl"
             xmlns:utilities="clr-namespace:tulo.ResourcesWpfLib.Utilities;assembly=tulo.ResourcesWpfLib"
             mc:Ignorable="d"
             d:DesignHeight="200"
             d:DesignWidth="600">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:DateOnlyToDateTimeConverter x:Key="DateOnlyToDateTimeConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Background="{StaticResource PanelBackgroundBrushColor}"
            BorderBrush="{StaticResource PanelBorderBrushColor}"
            BorderThickness="2"
            CornerRadius="5"
            Margin="1"
            Padding="4"
            SnapsToDevicePixels="True"
            MaxHeight="310"
            Width="578"
            HorizontalAlignment="Stretch">

        <Border.Effect>
            <DropShadowEffect Color="DarkGray"
                              BlurRadius="10"
                              ShadowDepth="2"
                              Opacity="0.5" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
            </Grid.RowDefinitions>

            <!--  payment Code  -->
            <Grid Grid.Row="0" Grid.Column="1">
                <Grid>
                    <ComboBox x:Name="cbPayment"
                              Template="{StaticResource ComboBoxCustomized}"
                              Height="24"
                              HorizontalAlignment="Left"
                              ItemsSource="{Binding PaymentMeansCodesObservableCollection}"
                              SelectedItem="{Binding SelectedPaymentMeansItem, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="DisplayText"
                              ToolTip="{Binding ToolTipPaymentMeansCode}"
                              Margin="0,2,0,4"
                              Padding="4,2"
                              MinWidth="180"
                              MaxWidth="220" />

                    <TextBlock Text="{Binding LabelPaymentMeansCode}"
                               Margin="5,1,30,0"
                               VerticalAlignment="Center"
                               Foreground="Gray"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=cbPayment}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>

            <!--  Payment Due date  -->
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <utilities:ExtendedDatePicker Grid.Row="0"
                                              Grid.Column="0"
                                              Tag="Due date"
                                              x:Name="PaymentDueDatePicker"
                                              HorizontalAlignment="Left"
                                              Width="116"
                                              Height="28"
                                              Language="de-DE"
                                              DisplayDateStart="1900-01-01"
                                              DisplayDateEnd="2099-12-31"
                                              SelectedDate="{Binding PaymentDueDate, Converter={StaticResource DateOnlyToDateTimeConverter}, UpdateSourceTrigger=PropertyChanged}"
                                              Text="{Binding PaymentDueDateText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                              ToolTip="{Binding ToolTipPaymentDueDateText}"
                                              Margin="0,0,0,0" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Margin="4,2,0,0"
                           Foreground="Red"
                           Visibility="{Binding HasDatePickerError, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                           Text="{Binding DatePickerErrorMessage}" />
            </Grid>

            <!--  Payment reference  -->

            <placeholder:PlaceholderTextBox Grid.Row="2"
                                            Grid.Column="1"
                                            Width="558"
                                            Text="{Binding PaymentReference, UpdateSourceTrigger=PropertyChanged}"
                                            ToolTip="{Binding ToolTipPaymentReference}"
                                            Placeholder="{Binding PlaceholderPaymentReference}"
                                            utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                            BorderThickness="0.5"
                                            HorizontalAlignment="Left"
                                            TextWrapping="Wrap"
                                            MinHeight="40"
                                            Margin="0,2,0,0"
                                            Padding="6,2" />

            <!--  Payment Terms  -->
            <placeholder:PlaceholderTextBox Grid.Row="3"
                                            Grid.Column="1"
                                            Width="558"
                                            Text="{Binding PaymentTerms, UpdateSourceTrigger=PropertyChanged}"
                                            ToolTip="{Binding ToolTipPaymentTerms}"
                                            Placeholder="{Binding PlaceholderPaymentTerms}"
                                            utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                            BorderThickness="0.5"
                                            HorizontalAlignment="Left"
                                            TextWrapping="Wrap"
                                            MinHeight="40"
                                            Margin="0,2,0,0"
                                            Padding="6,2" />
        </Grid>
    </Border>

</UserControl>
