<UserControl x:Class="tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.Controls.HeaderInvoicePositionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.Controls"
             xmlns:placeholder="clr-namespace:tulo.PlaceholderTextBoxControl;assembly=tulo.PlaceholderTextBoxControl"
             mc:Ignorable="d"
             d:DesignHeight="44"
             MaxWidth="1000"
             d:DesignWidth="1000">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource PanelBackgroundBrushColor}"
            BorderBrush="{StaticResource PanelBorderBrushColor}"
            BorderThickness="2"
            CornerRadius="5"
            Margin="1"
            Padding="4"
            SnapsToDevicePixels="True">

        <Border.Effect>
            <DropShadowEffect Color="DarkGray"
                              BlurRadius="10"
                              ShadowDepth="2"
                              Opacity="0.5" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="4" />
            </Grid.ColumnDefinitions>

            <placeholder:PlaceholderTextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Grid.Column="1"
                                            ToolTip="{Binding ToolTipSearchText}"
                                            Placeholder="🔍"
                                            BorderThickness="0.5"
                                            Margin="0,2,4,0"
                                            Width="300"
                                            Height="24"
                                            Padding="6,2" />

            <Button Name="createButton"
                    Grid.Column="3"
                    HorizontalAlignment="Center"
                    BorderBrush="Transparent"
                    Foreground="Transparent"
                    ToolTip="Insert new invoice position"
                    Command="{Binding OpenAddInvoicePositionViewCommand}">
                <Grid>
                    <Path Style="{StaticResource ContentButtonPathStyle}"
                          Data="{StaticResource CreateIconSVG}"
                          Fill="{StaticResource ButtonBrushIconColor}" />
                </Grid>
            </Button>

        </Grid>
    </Border>
</UserControl>

