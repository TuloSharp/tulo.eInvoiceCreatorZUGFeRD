<UserControl x:Class="tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.Controls.BuyerPartyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.Controls"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:system="clr-namespace:System;assembly=netstandard"
             xmlns:converters="clr-namespace:tulo.ResourcesWpfLib.Converters;assembly=tulo.ResourcesWpfLib"
             xmlns:placeholder="clr-namespace:tulo.PlaceholderTextBoxControl;assembly=tulo.PlaceholderTextBoxControl"
             xmlns:utilities="clr-namespace:tulo.ResourcesWpfLib.Utilities;assembly=tulo.ResourcesWpfLib"
             mc:Ignorable="d"
             d:DesignHeight="260"
             d:DesignWidth="320">
    <Border Background="{StaticResource PanelBackgroundBrushColor}"
            BorderBrush="{StaticResource PanelBorderBrushColor}"
            BorderThickness="2"
            CornerRadius="5"
            Margin="1"
            Padding="4"
            SnapsToDevicePixels="True"
            Width="Auto"
            MaxHeight="330"
            HorizontalAlignment="Stretch">

        <Border.Effect>
            <DropShadowEffect Color="DarkGray"
                              BlurRadius="10"
                              ShadowDepth="2"
                              Opacity="0.5" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <placeholder:PlaceholderTextBox Text="{Binding CompanyBuyerParty}"
                                                ToolTip="{Binding ToolTipCompanyBuyerParty}"
                                                Placeholder="{Binding PlaceholderCompanyBuyerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding FiscalIdBuyerParty}"
                                                ToolTip="{Binding ToolTipFiscalIdBuyerParty}"
                                                Placeholder="{Binding PlaceholderFiscalIdBuyerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding VatIdBuyerParty}"
                                                ToolTip="{Binding ToolTipVatIdBuyerParty}"
                                                Placeholder="{Binding PlaceholderVatIdBuyerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding ErpCustomerNumberBuyerParty}"
                                                ToolTip="{Binding ToolTipErpCustomerNumberBuyerParty}"
                                                Placeholder="{Binding PlaceholderErpCustomerNumberBuyerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding LeitwegIdBuyerParty}"
                                                ToolTip="{Binding ToolTipLeitwegIdBuyerParty}"
                                                Placeholder="{Binding PlaceholderLeitwegIdBuyerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding PersonBuyerParty}"
                                                ToolTip="{Binding ToolTipPersonBuyerParty}"
                                                Placeholder="{Binding PlaceholderPersonBuyerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="36" />
                    </Grid.ColumnDefinitions>

                    <placeholder:PlaceholderTextBox Grid.Column="0"
                                                    Text="{Binding StreetBuyerParty}"
                                                    ToolTip="{Binding ToolTipStreetBuyerParty}"
                                                    Placeholder="{Binding PlaceholderStreetBuyerParty}"
                                                    utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                    BorderThickness="0.5"
                                                    Margin="0,2,4,0"
                                                    Padding="6,2" />

                    <placeholder:PlaceholderTextBox Grid.Column="2"
                                                    Text="{Binding HouseNumberBuyerParty}"
                                                    ToolTip="{Binding ToolTipHouseNumberBuyerParty}"
                                                    Placeholder="{Binding PlaceholderHouseNumberBuyerParty}"
                                                    utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                    BorderThickness="0.5"
                                                    Margin="0,2,4,0"
                                                    Padding="6,2" />
                </Grid>


                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />

                    </Grid.ColumnDefinitions>
                    <placeholder:PlaceholderTextBox Grid.Column="0"
                                                    Text="{Binding PostalCodeBuyerParty}"
                                                    ToolTip="{Binding ToolTipPostalCodeBuyerParty}"
                                                    Placeholder="{Binding PlaceholderPostalCodeBuyerParty}"
                                                    utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                    BorderThickness="0.5"
                                                    Margin="0,2,4,0"
                                                    Padding="6,2" />

                    <placeholder:PlaceholderTextBox Grid.Column="2"
                                                    Text="{Binding CityBuyerParty}"
                                                    ToolTip="{Binding ToolTipCityBuyerParty}"
                                                    Placeholder="{Binding PlaceholderCityBuyerParty}"
                                                    utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                    BorderThickness="0.5"
                                                    Margin="0,2,4,0"
                                                    Padding="6,2" />

                    <placeholder:PlaceholderTextBox Grid.Column="4"
                                                    Text="{Binding CountryCodeBuyerParty}"
                                                    ToolTip="{Binding ToolTipCountryCodeBuyerParty}"
                                                    Placeholder="{Binding PlaceholderCountryCodeBuyerParty}"
                                                    utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                    BorderThickness="0.5"
                                                    Margin="0,2,4,0"
                                                    Padding="6,2" />
                </Grid>

                <placeholder:PlaceholderTextBox Text="{Binding PhoneBuyerParty}"
                                                ToolTip="{Binding ToolTipPhoneBuyerParty}"
                                                Placeholder="{Binding PlaceholderPhoneBuyerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding EmailAddressBuyerParty}"
                                                ToolTip="{Binding ToolTipEmailAddressBuyerParty}"
                                                Placeholder="{Binding PlaceholderEmailAddressBuyerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
