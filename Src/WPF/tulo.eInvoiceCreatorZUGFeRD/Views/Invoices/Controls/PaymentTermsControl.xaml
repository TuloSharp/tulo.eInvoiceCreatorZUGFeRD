<UserControl x:Class="tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.Controls.PaymentTermsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:utilities="clr-namespace:tulo.ResourcesWpfLib.Utilities;assembly=tulo.ResourcesWpfLib"
             xmlns:converters="clr-namespace:tulo.ResourcesWpfLib.Converters;assembly=tulo.ResourcesWpfLib"
             xmlns:placeholder="clr-namespace:tulo.PlaceholderTextBoxControl;assembly=tulo.PlaceholderTextBoxControl"
             mc:Ignorable="d"
             d:DesignHeight="200"
             d:DesignWidth="600">

    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:DateOnlyToDateTimeConverter x:Key="DateOnlyToDateTimeConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource PanelBackgroundBrushColor}"
            BorderBrush="{StaticResource PanelBorderBrushColor}"
            BorderThickness="2"
            CornerRadius="5"
            Margin="1"
            Padding="10"
            SnapsToDevicePixels="True"
            Width="auto"
            HorizontalAlignment="Stretch">

        <Border.Effect>
            <DropShadowEffect Color="DarkGray"
                              BlurRadius="10"
                              ShadowDepth="2"
                              Opacity="0.5" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Discount percentage + days + result date (display only)  -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <!--  %  -->
                    <placeholder:PlaceholderTextBox Grid.Column="0"
                                                    Placeholder="{Binding PlaceholderDiscountPercent}"
                                                    ToolTip="{Binding ToolTipDiscountPercent}"
                                                    BorderThickness="0.5"
                                                    Padding="6,2"
                                                    HorizontalAlignment="Left"
                                                    MaxLength="5"
                                                    Width="120"
                                                    utilities:MoneyInput.IsEnabled="True"
                                                    utilities:MoneyInput.ShowZeroWhenEmpty="False"
                                                    utilities:MoneyInput.Value="{Binding DiscountPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    utilities:MoneyInput.Mode="ShiftCents" />
                    <!--  Days  -->
                    <placeholder:PlaceholderTextBox Grid.Column="2"
                                                    Text="{Binding DiscountDays, UpdateSourceTrigger=PropertyChanged}"
                                                    Placeholder="{Binding PlaceholderDiscountDays}"
                                                    ToolTip="{Binding ToolTipDiscountDays}"
                                                    utilities:TextBoxProperties.AllowedCharactersRegex="^[0-9]*$"
                                                    BorderThickness="0.5"
                                                    Padding="6,2"
                                                    HorizontalAlignment="Left"
                                                    MaxLength="3"
                                                    Width="70" />
                </Grid>

                <!--  Basis date  -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <utilities:ExtendedDatePicker Grid.Column="0"
                                                  x:Name="DiscountBasisDatePicker"
                                                  HorizontalAlignment="Left"
                                                  Tag="{Binding TagDiscountBasisDate}"
                                                  Width="140"
                                                  Height="28"
                                                  Language="de-DE"
                                                  DisplayDateStart="1900-01-01"
                                                  DisplayDateEnd="2099-12-31"
                                                  SelectedDate="{Binding DiscountBasisDate, Converter={StaticResource DateOnlyToDateTimeConverter}, UpdateSourceTrigger=PropertyChanged}"
                                                  Text="{Binding DiscountBasisDateText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                  ToolTip="{Binding ToolTipDiscountBasisDate}"
                                                  Margin="0,4,0,0" />

                    <!--  Preview-Text (JSON Description)  -->
                    <placeholder:PlaceholderTextBox Grid.Column="4"
                                                    HorizontalAlignment="Left"
                                                    Text="{Binding DiscountPreviewText}"
                                                    Placeholder="{Binding PlaceholderDiscountPreviewText}"
                                                    ToolTip="{Binding ToolTipDiscountPreviewText}"
                                                    BorderThickness="0.5"
                                                    Padding="6,2"
                                                    Width="430"
                                                    Margin="0,4,0,0" />
                    <!--  IsReadOnly="True"  -->
                </Grid>

                <TextBlock Grid.Row="2"
                           Margin="10,2,0,0"
                           Foreground="Red"
                           Visibility="{Binding HasDiscountBasisDateError, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                           Text="{Binding DiscountBasisDateErrorMessage}" />

            </Grid>

            <!--  No deduction / Due date range  -->
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <utilities:ExtendedDatePicker Grid.Column="0"
                                                  x:Name="NoDiscountDueDatePicker"
                                                  Tag="{Binding TagPaymentDueDateRangeText}"
                                                  HorizontalAlignment="Left"
                                                  Width="140"
                                                  Height="28"
                                                  Language="de-DE"
                                                  DisplayDateStart="1900-01-01"
                                                  DisplayDateEnd="2099-12-31"
                                                  SelectedDate="{Binding PaymentDueDateRange, Converter={StaticResource DateOnlyToDateTimeConverter}, UpdateSourceTrigger=PropertyChanged}"
                                                  Text="{Binding PaymentDueDateRangeText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                  ToolTip="{Binding ToolTipPaymentDueDateRangeText}"
                                                  Margin="0,4,0,0" />

                    <placeholder:PlaceholderTextBox Grid.Column="2"
                                                    Text="{Binding NoDiscountPreviewText}"
                                                    Placeholder="{Binding PlaceholderNoDiscountPreviewText}"
                                                    ToolTip="{Binding ToolTipNoDiscountPreviewText}"
                                                    HorizontalAlignment="Left"
                                                    BorderThickness="0.5"
                                                    Padding="6,2"
                                                    Width="430"
                                                    TextWrapping="Wrap"
                                                    Margin="0,4,0,0" />
                    <!--  IsReadOnly="True"  -->
                </Grid>

                <TextBlock Grid.Row="1"
                           Margin="4,2,0,0"
                           Foreground="Red"
                           Visibility="{Binding HasPaymentDueDateRangeError, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                           Text="{Binding PaymentDueDateRangeErrorMessage}" />

            </Grid>
        </Grid>
    </Border>
</UserControl>
