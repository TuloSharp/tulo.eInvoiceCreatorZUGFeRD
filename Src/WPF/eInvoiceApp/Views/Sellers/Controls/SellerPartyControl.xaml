<UserControl x:Class="tulo.eInvoice.eInvoiceApp.Views.Sellers.Controls.SellerPartyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.eInvoice.eInvoiceApp.Views.Sellers.Controls"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:system="clr-namespace:System;assembly=netstandard"
             xmlns:converters="clr-namespace:tulo.ResourcesWpfLib.Converters;assembly=tulo.ResourcesWpfLib"
             xmlns:placeholder="clr-namespace:tulo.PlaceholderTextBoxControl;assembly=tulo.PlaceholderTextBoxControl"
             xmlns:utilities="clr-namespace:tulo.ResourcesWpfLib.Utilities;assembly=tulo.ResourcesWpfLib"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="350">
    <Border Background="{StaticResource PanelBackgroundBrushColor}"
            BorderBrush="{StaticResource PanelBorderBrushColor}"
            BorderThickness="2"
            CornerRadius="5"
            Margin="1"
            Padding="4"
            SnapsToDevicePixels="True"
            Width="Auto"
            MaxHeight="300"
            MaxWidth="400"
            HorizontalAlignment="Stretch">

        <Border.Effect>
            <DropShadowEffect Color="DarkGray"
                              BlurRadius="10"
                              ShadowDepth="2"
                              Opacity="0.5" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <placeholder:PlaceholderTextBox Text="{Binding CompanySellerParty}"
                                                ToolTip="{Binding ToolTipCompanySellerParty}"
                                                Placeholder="{Binding PlaceholderCompanySellerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding FiscalIdSellerParty}"
                                                ToolTip="{Binding ToolTipFiscalIdSellerParty}"
                                                Placeholder="{Binding PlaceholderFiscalIdSellerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding VatIdSellerParty}"
                                                ToolTip="{Binding ToolTipVatIdSellerParty}"
                                                Placeholder="{Binding PlaceholderVatIdSellerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding ErpCustomerNumberSellerParty}"
                                                ToolTip="{Binding ToolTipErpCustomerNumberSellerParty}"
                                                Placeholder="{Binding PlaceholderErpCustomerNumberSellerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding LeitwegIdSellerParty}"
                                                ToolTip="{Binding ToolTipLeitwegIdSellerParty}"
                                                Placeholder="{Binding PlaceholderLeitwegIdSellerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding PersonSellerParty}"
                                                ToolTip="{Binding ToolTipPersonSellerParty}"
                                                Placeholder="{Binding PlaceholderPersonSellerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding AddressSellerParty}"
                                                ToolTip="{Binding ToolTipAddressSellerParty}"
                                                Placeholder="{Binding PlaceholderAddressSellerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                Grid.Column="2"
                                                BorderThickness="0.5"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding PhoneSellerParty}"
                                                ToolTip="{Binding ToolTipPhoneSellerParty}"
                                                Placeholder="{Binding PlaceholderPhoneSellerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

                <placeholder:PlaceholderTextBox Text="{Binding EmailAddressSellerParty}"
                                                ToolTip="{Binding ToolTipEmailAddressSellerParty}"
                                                Placeholder="{Binding PlaceholderEmailAddressSellerParty}"
                                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                                BorderThickness="0.5"
                                                Grid.Column="2"
                                                Margin="0,2,4,0"
                                                Padding="6,2" />

            </StackPanel>
        </Grid>
    </Border>
</UserControl>

