<UserControl x:Class="tulo.eInvoice.eInvoiceApp.Views.Sellers.Controls.InvoiceNote"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.eInvoice.eInvoiceApp.Views.Sellers.Controls"
             xmlns:converters="clr-namespace:tulo.ResourcesWpfLib.Converters;assembly=tulo.ResourcesWpfLib"
             xmlns:placeholder="clr-namespace:tulo.PlaceholderTextBoxControl;assembly=tulo.PlaceholderTextBoxControl"
             xmlns:utilities="clr-namespace:tulo.ResourcesWpfLib.Utilities;assembly=tulo.ResourcesWpfLib"
             mc:Ignorable="d"
             d:DesignHeight="50"
             d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:DateOnlyToDateTimeConverter x:Key="DateOnlyToDateTimeConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Background="{StaticResource PanelBackgroundBrushColor}"
            BorderBrush="{StaticResource PanelBorderBrushColor}"
            BorderThickness="2"
            CornerRadius="5"
            Margin="1"
            Padding="4"
            SnapsToDevicePixels="True"
            MaxHeight="200"
            HorizontalAlignment="Stretch">

        <Border.Effect>
            <DropShadowEffect Color="DarkGray"
                              BlurRadius="10"
                              ShadowDepth="2"
                              Opacity="0.5" />
        </Border.Effect>

        <!--  invoice notes  -->
        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      HorizontalAlignment="Left"
                      SelectedValue="{Binding SubjectCodeInvoiceNote, UpdateSourceTrigger=PropertyChanged}"
                      ToolTip="{Binding ToolTipSubjectCodeInvoiceNote}"
                      SelectedValuePath="Tag"
                      Height="28"
                      Width="50">
                <ComboBoxItem Content="REG" Tag="REG" />
                <ComboBoxItem Content="AAI" Tag="AAI" />
                <ComboBoxItem Content="PTM" Tag="PTM" />
            </ComboBox>
            <placeholder:PlaceholderTextBox Grid.Column="2"
                                Width="400"
                                MinHeight="28"
                                MaxHeight="160"
                                Text="{Binding ContentInvoiceNote, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{Binding ToolTipContentInvoiceNote}"
                                Placeholder="{Binding PlaceholderContentInvoiceNote}"
                                utilities:TextBoxProperties.AllowedCharactersRegex="^[^~]*$"
                                BorderThickness="0.5"
                                HorizontalAlignment="Left"
                                Margin="0,1,0,0"
                                Padding="6,2"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                VerticalContentAlignment="Top"
                                VerticalScrollBarVisibility="Disabled"
                                HorizontalScrollBarVisibility="Disabled" />
        </Grid>

    </Border>
</UserControl>
