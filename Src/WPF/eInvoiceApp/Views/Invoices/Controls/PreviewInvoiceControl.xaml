<UserControl x:Class="tulo.eInvoiceApp.Views.Invoices.Controls.PreviewInvoiceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.eInvoiceApp.Views.Invoices.Controls"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:custombehaviors="clr-namespace:tulo.ResourcesWpfLib.Utilities;assembly=tulo.ResourcesWpfLib"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Border Background="{StaticResource PanelBackgroundBrushColor}"
            BorderBrush="{StaticResource PanelBorderBrushColor}"
            BorderThickness="2"
            CornerRadius="5"
            Margin="1"
            Padding="4"
            SnapsToDevicePixels="True"
            HorizontalAlignment="Stretch">

        <Border.Effect>
            <DropShadowEffect Color="DarkGray"
                              BlurRadius="10"
                              ShadowDepth="2"
                              Opacity="0.5" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="4" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="4" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid  Grid.Row="1" Background="AliceBlue" Height="40">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <Button Name="RefreshPreviewButton"
                    HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        
                    Grid.Column="1"
                    Command="{Binding UpdatePreviewInvoicePdfCommand}"
                    ToolTip="Refresh pdf preview">
                    <Grid>
                        <Viewbox Style="{StaticResource ViewBox4Icon}">
                            <Path Data="{StaticResource RefreshIconSVG}"
                              Style="{StaticResource ContentButtonPathStyle}"
                              Fill="{StaticResource ButtonBrushIconColor}"
                              Width="auto"
                              Height="auto" />
                        </Viewbox>
                    </Grid>
                </Button>
            </Grid>

            <wv2:WebView2 Name="webView" Grid.Row="3">
                <behaviors:Interaction.Behaviors>
                    <custombehaviors:WebView2ViewerBehavior HtmlContent="{Binding DocumentSource}" />
                </behaviors:Interaction.Behaviors>
            </wv2:WebView2>
        </Grid>
    </Border>
</UserControl>