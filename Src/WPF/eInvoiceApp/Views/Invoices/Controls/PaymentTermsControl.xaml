<UserControl x:Class="tulo.eInvoice.eInvoiceApp.Views.Invoices.Controls.PaymentTermsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:utilities="clr-namespace:tulo.ResourcesWpfLib.Utilities;assembly=tulo.ResourcesWpfLib"
             xmlns:converters="clr-namespace:tulo.ResourcesWpfLib.Converters;assembly=tulo.ResourcesWpfLib"
             xmlns:placeholder="clr-namespace:tulo.PlaceholderTextBoxControl;assembly=tulo.PlaceholderTextBoxControl"
             mc:Ignorable="d"
             d:DesignHeight="280"
             d:DesignWidth="300">

    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:DateOnlyToDateTimeConverter x:Key="DateOnlyToDateTimeConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource PanelBackgroundBrushColor}"
            BorderBrush="{StaticResource PanelBorderBrushColor}"
            BorderThickness="2"
            CornerRadius="5"
            Margin="1"
            Padding="10"
            SnapsToDevicePixels="True"
            Width="auto"
            HorizontalAlignment="Stretch">

        <Border.Effect>
            <DropShadowEffect Color="DarkGray"
                              BlurRadius="10"
                              ShadowDepth="2"
                              Opacity="0.5" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Skonto Bereich -->
   

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Checkbox -->
                    <CheckBox Grid.Row="0"
                              Content="Skonto anbieten"
                              IsChecked="{Binding HasSkonto, UpdateSourceTrigger=PropertyChanged}"
                              FontSize="14"
                              Margin="2,0,0,0"/>

                    <!-- Skonto Prozent + Tage + Ergebnisdatum (nur Anzeige) -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- % -->
                        <placeholder:PlaceholderTextBox Grid.Column="0"
                                                        Text="{Binding SkontoPercent, UpdateSourceTrigger=PropertyChanged}"
                                                        Placeholder="... % Skonto"
                                                        ToolTip="Skonto in Prozent"
                                                        BorderThickness="0.5"
                                                        Padding="6,2"
                                                        IsEnabled="{Binding HasSkonto}"
                                                        HorizontalAlignment="Left"
                                                        Width="90"/>

                      

                        <!-- Tage -->
                        <placeholder:PlaceholderTextBox Grid.Column="2"
                                                        Text="{Binding SkontoDays, UpdateSourceTrigger=PropertyChanged}"
                                                        Placeholder="till n days"
                                                        ToolTip="Skonto-Frist in Tagen"
                                                        BorderThickness="0.5"
                                                        Padding="6,2"
                                                        IsEnabled="{Binding HasSkonto}"
                                                        HorizontalAlignment="Left"
                                                        Width="155"/>

                        <TextBlock Grid.Column="4"
                                   Text="{Binding SkontoUntilDateText}"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   Margin="8,0,0,0"
                                   Opacity="{Binding HasSkonto, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>

                    <!-- Basisdatum -->
               


                        <utilities:ExtendedDatePicker Grid.Row="6"
                                                      x:Name="SkontoBasisDatePicker"
                                                       HorizontalAlignment="Left"
                                                       Tag="Basis date"
                                                      Width="140"
                                                      Height="28"
                                                      Language="de-DE"
                                                      DisplayDateStart="1900-01-01"
                                                      DisplayDateEnd="2099-12-31"
                                                      SelectedDate="{Binding SkontoBasisDate, Converter={StaticResource DateOnlyToDateTimeConverter}, UpdateSourceTrigger=PropertyChanged}"
                                                      Text="{Binding SkontoBasisDateText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                      ToolTip="Basisdatum für Skonto (z.B. Rechnungsdatum)"
                                                      IsEnabled="{Binding HasSkonto}"
                                                      Margin="0,0,0,0"/>

                        
                        <TextBlock Grid.Row="7"
                                   Margin="10,2,0,0"
                                   Foreground="Red"
                                   Visibility="{Binding HasSkontoBasisDateError, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                                   Text="{Binding SkontoBasisDateErrorMessage}" />
                        
                

                    <!-- Preview-Text (genau wie in deinem JSON Description) -->
                    <placeholder:PlaceholderTextBox Grid.Row="8"
                                                    HorizontalAlignment="Left"
                                                    Text="{Binding SkontoPreviewText}"
                                                    Placeholder="Bis zum --.--.---- erhalten Sie ... % Skonto"
                                                    IsReadOnly="True"
                                                    BorderThickness="0.5"
                                                    Padding="6,2"
                                           Width="250"
                                                    TextWrapping="Wrap"
                                                    Margin="0,8,0,0"/>
                </Grid>
          

            <!-- Ohne Abzug / Fälligkeit Bereich -->
            <Border Grid.Row="3"
                    Background="#0A000000"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>



                
                        <utilities:ExtendedDatePicker  Grid.Row="0"
                                                  x:Name="NoDiscountDueDatePicker"
                                                  Tag="payable by"
                                                   HorizontalAlignment="Left"
                                                  Width="140"
                                                  Height="28"
                                                  Language="de-DE"
                                                  DisplayDateStart="1900-01-01"
                                                  DisplayDateEnd="2099-12-31"
                                                  SelectedDate="{Binding PaymentDueDate, Converter={StaticResource DateOnlyToDateTimeConverter}, UpdateSourceTrigger=PropertyChanged}"
                                                  Text="{Binding PaymentDueDateText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                  ToolTip="{Binding ToolTipPaymentDueDateText}"
                                                  Margin="0,0,0,0"/> 
                        
                      
                

                    <TextBlock Grid.Row="1"
                               Margin="4,2,0,0"
                               Foreground="Red"
                               Visibility="{Binding HasDatePickerError, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                               Text="{Binding DatePickerErrorMessage}" /> 
                    
                    <placeholder:PlaceholderTextBox Grid.Row="2"
                                                    Text="{Binding NoDiscountPreviewText}"
                                                    Placeholder="Bis zum ... ohne Abzug"
                                                    HorizontalAlignment="Left"
                                                    IsReadOnly="True"
                                                    BorderThickness="0.5"
                                                    Padding="6,2"
                                                    Width="250"
                                                    TextWrapping="Wrap"
                                                    Margin="0,6,0,0"/>

                   
                </Grid>
            </Border>

        </Grid>
    </Border>
</UserControl>
