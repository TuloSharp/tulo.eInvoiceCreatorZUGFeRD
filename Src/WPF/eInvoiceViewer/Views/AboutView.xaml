<UserControl x:Class="tulo.eInvoice.eInvoiceViewer.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.eInvoice.eInvoiceViewer.Views"
             xmlns:md="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
             xmlns:custombehaviors="clr-namespace:tulo.ResourcesWpfLib.Utilities;assembly=tulo.ResourcesWpfLib"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="15" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Version}"
                   Grid.Row="1"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10" />

        <!--  Markdown Display  -->
        <ScrollViewer Grid.Row="2">
            <md:MarkdownViewer Markdown="{Binding DisclaimerText}" custombehaviors:MarkdownBehavior.LinkCommand="{Binding OpenHyperlinkCommand}" />
        </ScrollViewer>
    </Grid>
</UserControl>
