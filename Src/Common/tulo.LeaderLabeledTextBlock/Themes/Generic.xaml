<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:tulo.LeaderLabeledTextBlock">

    <local:CornerGeometryConverter x:Key="CornerGeometryConverter" />

    <Style TargetType="{x:Type local:LeaderLabeledTextBlock}">
        <Setter Property="Stroke" Value="Black"/>
        <Setter Property="StrokeThickness" Value="0.5"/>
        <Setter Property="CornerWidth" Value="52"/>
        <Setter Property="CornerHeight" Value="4"/>
        <Setter Property="CornerShiftX" Value="0"/>

        <Setter Property="TextFontSize" Value="12"/>
        <Setter Property="LabelFontSize" Value="6"/>
        <Setter Property="TextForeground" Value="Black"/>
        <Setter Property="LabelForeground" Value="Black"/>

        <Setter Property="TextAlignment" Value="Left"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Setter Property="TextTrimming" Value="None"/>

        <Setter Property="LabelAlignToCorner" Value="False"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:LeaderLabeledTextBlock}">
                    <Grid x:Name="PART_Root" SnapsToDevicePixels="True">

                        <!-- FIX: immer Stretch, kein Converter -->
                        <Grid x:Name="PART_Content"
                          VerticalAlignment="Top"
                          HorizontalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Bottom">

                                <Path Width="{TemplateBinding CornerWidth}"
                                  Height="{TemplateBinding CornerHeight}"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Bottom"
                                  Stroke="{TemplateBinding Stroke}"
                                  StrokeThickness="{TemplateBinding StrokeThickness}"
                                  StrokeLineJoin="Miter"
                                  StrokeStartLineCap="Square"
                                  StrokeEndLineCap="Square"
                                  IsHitTestVisible="False"
                                  Panel.ZIndex="0">
                                    <Path.RenderTransform>
                                        <TranslateTransform X="{TemplateBinding CornerShiftX}" />
                                    </Path.RenderTransform>

                                    <Path.Data>
                                        <MultiBinding Converter="{StaticResource CornerGeometryConverter}">
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="CornerWidth"/>
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="CornerHeight"/>
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="StrokeThickness"/>
                                        </MultiBinding>
                                    </Path.Data>
                                </Path>

                                <!-- FIX: HorizontalAlignment Right -->
                                <TextBlock Text="{TemplateBinding Text}"
                                       FontSize="{TemplateBinding TextFontSize}"
                                       Foreground="{TemplateBinding TextForeground}"
                                       TextAlignment="{TemplateBinding TextAlignment}"
                                       TextWrapping="{TemplateBinding TextWrapping}"
                                       TextTrimming="{TemplateBinding TextTrimming}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Margin="0,0,2,0"
                                       Panel.ZIndex="10"/>
                            </Grid>

                            <!-- FIX: TextAlignment Right dazu -->
                            <TextBlock Grid.Row="1"
                                   Margin="0,-1,0,0"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"
                                   Text="{TemplateBinding Label}"
                                   FontSize="{TemplateBinding LabelFontSize}"
                                   Foreground="{TemplateBinding LabelForeground}"/>
                        </Grid>

                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_Root" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

  
</ResourceDictionary>
