                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource MainBrushColor}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>