<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--#region  Colors-->
    <Color x:Key="MainColor">#0066FF</Color>
    <Color x:Key="PanelColor">White</Color>
    <Color x:Key="PanelBorderColor">#808080</Color>
    <Color x:Key="PanelBackgroundColor">#F0F0F0</Color>
    <Color x:Key="TitleIconsColor">White</Color>
    <Color x:Key="GroupBoxColor">#9B9B9B</Color>
    <Color x:Key="BorderTextBoxLabelColor">#B0B2B8</Color>
    <Color x:Key="BackgroundTextBoxDisableColor">#E3E3E3</Color>
    <Color x:Key="GreenTextBox">LightGreen</Color>
    <Color x:Key="ButtonIconColor">White</Color>
    <Color x:Key="WarningColor">Orange</Color>
    <Color x:Key="ErrorColor">#F05944</Color>
    <Color x:Key="HighlightColor">#00BFFF</Color>
    <Color x:Key="FocusButtonColor">DarkOrange</Color>
    <Color x:Key="TextButtonColor">Black</Color>
    <Color x:Key="BorderColor">#424242</Color>
    <Color x:Key="DefaultWhiteFieldColor">White</Color>
    <Color x:Key="ListViewColor">DeepPink</Color>
    <Color x:Key="ButtonLightColor">#9FE4A3</Color>
    <Color x:Key="MainWindowBorderColor">#404040</Color>
    <Color x:Key="HeaderMainWindowColor">Orange</Color>
    <Color x:Key="BackgroundNavigatorColor">White</Color>
    <Color x:Key="DarkGrayColor" x:Shared="False">#AAAAAA</Color>
    <Color x:Key="LightGrayColor" x:Shared="False">#D9D9D9</Color>
    <Color x:Key="ButtonIconSecundaryColor" x:Shared="False">White</Color>
    <Color x:Key="ButtonIconPrimaryColor" x:Shared="False">#0066FF</Color>
    <Color x:Key="InfoColor">#191970</Color>
    <Color x:Key="TitleIconColor">#4CAF50</Color>
    <Color x:Key="IconLabelColor">Black</Color>
    <Color x:Key="HintColor">#77DD77</Color>
    <Color x:Key="LabelColor">DarkMagenta</Color>
    <Color x:Key="LabelViewColor">DarkOrange</Color>
    <Color x:Key="BorderLightColor">Orange</Color>
    <Color x:Key="BorderDarkColor">OrangeRed</Color>
    <Color x:Key="SpinnerTextColor">#0066FF</Color>
    <Color x:Key="AltKeyColor">#37C837</Color>
    <Color x:Key="ScrollBarThumbColorNormal">#66000000</Color>
    <Color x:Key="ScrollBarThumbColorHover">#99000000</Color>
    <Color x:Key="ScrollBarThumbColorPressed">#CC000000</Color>
    <Color x:Key="ScrollBarThumbColorDisabled">#33000000</Color>
    <!--#endregion-->

    <!--#region Brushes-->
    <SolidColorBrush x:Key="MainBrushColor" Color="{StaticResource MainColor}" />
    <SolidColorBrush x:Key="PanelBrushColor" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="PanelBorderBrushColor" Color="{StaticResource PanelBorderColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrushColor" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="TitleIconsBrushColor" Color="{StaticResource TitleIconsColor}" />
    <SolidColorBrush x:Key="GroupBoxBrushColor" Color="{StaticResource GroupBoxColor}" />
    <SolidColorBrush x:Key="BorderTextBoxLabelBrushColor" Color="{StaticResource BorderTextBoxLabelColor}" />
    <SolidColorBrush x:Key="BackgroundTextBoxDisableBrushColor" Color="{StaticResource BackgroundTextBoxDisableColor}" />
    <SolidColorBrush x:Key="GreenTextBoxBrushColor" Color="{StaticResource GreenTextBox}" />
    <SolidColorBrush x:Key="ButtonBrushIconColor" Color="{StaticResource ButtonIconColor}" />
    <SolidColorBrush x:Key="WarningBrushColor" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrushColor" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="InfoBrushColor" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="HighlightBrushColor" Color="{StaticResource HighlightColor}" />
    <SolidColorBrush x:Key="FocusButtonBrushColor" Color="{StaticResource FocusButtonColor}" />
    <SolidColorBrush x:Key="TextButtonBrushColor" Color="{StaticResource TextButtonColor}" />
    <SolidColorBrush x:Key="BorderBrushColor" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="ListViewBrushColor" Color="{StaticResource ListViewColor}" />
    <SolidColorBrush x:Key="ButonLightBrushColor" Color="{StaticResource ButtonLightColor}" />
    <SolidColorBrush x:Key="MainWindowBorderBrushColor" Color="{StaticResource MainWindowBorderColor}" />
    <SolidColorBrush x:Key="HeaderMainWindowBrushColor" Color="{StaticResource HeaderMainWindowColor}" />
    <SolidColorBrush x:Key="BackgroundNavigatorBrushColor" Color="{StaticResource BackgroundNavigatorColor}" />
    <SolidColorBrush x:Key="DarkGrayColorBrush"
                     x:Shared="False"
                     Color="{StaticResource DarkGrayColor}" />
    <SolidColorBrush x:Key="LightGrayColorBrush"
                     x:Shared="False"
                     Color="{StaticResource LightGrayColor}" />
    <SolidColorBrush x:Key="ButtonIconSecundaryColorBrush"
                     x:Shared="False"
                     Color="{StaticResource ButtonIconSecundaryColor}" />
    <SolidColorBrush x:Key="ButtonIconPrimaryColorBrush"
                     x:Shared="False"
                     Color="{StaticResource ButtonIconPrimaryColor}" />
    <SolidColorBrush x:Key="InfoColorBrush" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="HighlightColorBrush" Color="{StaticResource HighlightColor}" />
    <SolidColorBrush x:Key="TitleIconColorBrush" Color="{StaticResource TitleIconColor}" />
    <SolidColorBrush x:Key="IconLabelColorBrush" Color="{StaticResource IconLabelColor}" />
    <SolidColorBrush x:Key="HintColorBrush" Color="{StaticResource HintColor}" />
    <SolidColorBrush x:Key="LabelColorBrush" Color="{StaticResource LabelColor}" />
    <SolidColorBrush x:Key="LabelViewColorBrush" Color="{StaticResource LabelViewColor}" />
    <SolidColorBrush x:Key="BorderLightBrusholor" Color="{StaticResource BorderLightColor}" />
    <SolidColorBrush x:Key="BorderDarkBrushColor" Color="{StaticResource BorderDarkColor}" />
    <SolidColorBrush x:Key="SpinnerTextBrushColor" Color="{StaticResource SpinnerTextColor}" />
    <SolidColorBrush x:Key="AltKeyBrushColor" Color="{StaticResource AltKeyColor}" />
    <SolidColorBrush x:Key="ScrollBarThumbBrushNormal" Color="{StaticResource ScrollBarThumbColorNormal}" />
    <SolidColorBrush x:Key="ScrollBarThumbBrushHover" Color="{StaticResource ScrollBarThumbColorHover}" />
    <SolidColorBrush x:Key="ScrollBarThumbBrushPressed" Color="{StaticResource ScrollBarThumbColorPressed}" />
    <SolidColorBrush x:Key="ScrollBarThumbBrushDisabled" Color="{StaticResource ScrollBarThumbColorDisabled}" />
    <SolidColorBrush x:Key="ScrollBarTrackBackgroundBrush" Color="Transparent" />
    <!--#endregion-->

    <!--#region ContentPresenter-->
    <Style TargetType="{x:Type ContentPresenter}">
        <Setter Property="RecognizesAccessKey" Value="True" />
    </Style>
    <!--#endregion-->

    <!--#region Defines style for MainWindow-->
    <Style TargetType="{x:Type Panel}" x:Key="MainWindowPanelStyle">
        <Setter Property="Margin" Value="0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}, Path=WindowState}" Value="Maximized">
                <Setter Property="Margin" Value="6" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <!--#endregion-->

    <!--#region Reusable rounded UserControl style-->
    <Style x:Key="RoundedUserControlStyle" TargetType="UserControl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="UserControl">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="4"
                                              ShadowDepth="2"
                                              Opacity="0.25" />
                        </Border.Effect>
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!--#endregion-->

    <!--#region Defines style for Image-->
    <Style TargetType="{x:Type Image}" x:Key="MainIcon">
        <Setter Property="Margin" Value="1,0,0,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Source" Value="pack://application:,,,/tulo.ResourcesWpfLib;component/Icons/MainIcon.png" />
    </Style>
    <!--#endregion-->

    <!--#region Label Style-->
    <Style TargetType="{x:Type Label}">
        <Setter Property="Margin" Value="4" />
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="Black" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <!--#endregion-->

    <!--#region Display Label Style-->
    <Style TargetType="{x:Type Label}" x:Key="DisplayLabel">
        <Setter Property="Margin" Value="4" />
        <Setter Property="Foreground" Value="{StaticResource TextButtonBrushColor}" />
        <Setter Property="Background" Value="{StaticResource BackgroundTextBoxDisableBrushColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderTextBoxLabelBrushColor}" />
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="DarkBlue" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <!--#endregion-->

    <!--#region Validation Label-->
    <Style TargetType="{x:Type Label}" x:Key="ValidationTextLabel">
        <Setter Property="Foreground" Value="Red" />
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="Padding" Value="4,0,0,0" />
        <Setter Property="Visibility" Value="Hidden" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <!--#endregion-->

    <!--#region TextBox-->
    <Style TargetType="{x:Type TextBox}" x:Key="TextBoxBase">
        <Setter Property="Margin" Value="4,4,0,4" />
        <Setter Property="Foreground" Value="{StaticResource TextButtonBrushColor}" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Width" Value="400" />
        <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="border"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="false"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="{StaticResource BackgroundTextBoxDisableBrushColor}" />
                            <Setter TargetName="PART_ContentHost" Property="Background" Value="{StaticResource BackgroundTextBoxDisableBrushColor}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource HighlightBrushColor}" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="true">
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource HighlightBrushColor}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsReadOnly" Value="False">
                <Setter Property="Background" Value="White" />
            </Trigger>
        </Style.Triggers>

    </Style>
    <!--#endregion-->

    <!--#region Display Textbox-->
    <Style TargetType="{x:Type TextBox}" x:Key="DisplayTextBox">
        <Setter Property="Margin" Value="4,2,0,0" />
        <Setter Property="Foreground" Value="{StaticResource TextButtonBrushColor}" />
        <Setter Property="Background" Value="{StaticResource BackgroundTextBoxDisableBrushColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderTextBoxLabelBrushColor}" />
    </Style>
    <!--#endregion-->

    <!--#region TextBox ValidatonRule-->
    <Style TargetType="{x:Type TextBox}" x:Key="TextBoxValidationRule">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="Red" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Margin" Value="4,2,0,0" />
        <Setter Property="Width" Value="400" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <!--#endregion-->

    <!--#region TextBox overwrite base style-->
    <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxBase}" />
    <Style TargetType="TextBox"
           BasedOn="{StaticResource TextBoxBase}"
           x:Key="TextBoxMiddleWidth">
        <Setter Property="Width" Value="270" />
    </Style>

    <Style TargetType="TextBox"
           BasedOn="{StaticResource TextBoxBase}"
           x:Key="TextBoxSmallWidth">
        <Setter Property="Width" Value="135" />
    </Style>
    <!--#endregion-->

    <!--#region TextBlock for RadioButton-->
    <Style TargetType="TextBlock" x:Key="ShortcutText">
        <Setter Property="TextAlignment" Value="center" />
        <Setter Property="Width" Value="10" />
        <Setter Property="Height" Value="13" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Background" Value="{StaticResource ButtonIconPrimaryColorBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ButtonBrushIconColor}" />
    </Style>
    <!--#endregion-->

    <!--#region textblock for radiobutton-->
    <Style x:Key="TextForRadioButton" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource IconLabelColorBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FontWeight" Value="Thin" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>
    <!--#endregion-->

    <!--#region AccessText for RadioButton-->
    <Style TargetType="AccessText" x:Key="ShortcutAccessText">
        <Setter Property="FontSize" Value="6" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="Transparent" />
    </Style>
    <!--#endregion-->


    <!--#region Border-->
    <Style x:Key="CustomBorderStyle" TargetType="{x:Type Border}">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderTextBoxLabelBrushColor}" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="SnapsToDevicePixels" Value="True" />

        <Style.Triggers>
            <!--  Mouse over the border  -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource HighlightBrushColor}" />
            </Trigger>

            <!--  TextBox focused (focus is on TextBox, not on Border)  -->
            <DataTrigger Binding="{Binding IsFocused, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource HighlightBrushColor}" />
            </DataTrigger>

            <!--  TextBox disabled  -->
            <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="False">
                <Setter Property="Background" Value="{StaticResource BackgroundTextBoxDisableBrushColor}" />
                <Setter Property="BorderBrush" Value="{StaticResource BackgroundTextBoxDisableBrushColor}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <!--#endregion-->

    <!--#region ToggleButton-->
    <Style TargetType="{x:Type ToggleButton}">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Background" Value="DarkGray" />
        <Setter Property="Foreground" Value="DarkGray" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Margin="{TemplateBinding Margin}"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="FocusVisualStyle">
            <Setter.Value>
                <Style>
                    <Setter Property="Control.Template">
                        <Setter.Value>
                            <ControlTemplate>
                                <Rectangle Margin="0"
                                           Stroke="{StaticResource FocusButtonBrushColor}"
                                           StrokeThickness="2" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                            To="LightGray"
                                            Duration="0:0:0.2" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                            To="DarkGray"
                                            Duration="0:0:0.2" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <!--#endregion-->


    <!--  #Region Modern ToggleButton  -->
    <Style x:Key="ModernSwitchToggle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="20" />

        <Setter Property="Focusable" Value="False" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <!--  Track  -->
                        <Border CornerRadius="10">
                            <Border.Background>
                                <SolidColorBrush x:Name="TrackBrush" Color="#DADADA" />
                            </Border.Background>
                        </Border>

                        <Ellipse Width="16"
                                 Height="16"
                                 Fill="White"
                                 Margin="2"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center">
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="ThumbTransform" X="0" />
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="6"
                                                  ShadowDepth="1"
                                                  Opacity="0.22" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="TrackBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#22C55E"
                                                        Duration="0:0:0.12" />

                                        <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="18"
                                                         Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>

                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="TrackBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#DADADA"
                                                        Duration="0:0:0.12" />

                                        <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="0"
                                                         Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!--  Hover  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.95" />
                        </Trigger>

                        <!--  Disabled  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!--#endregion-->

    <!--#region Button-->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="32" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Background" Value="{StaticResource ButtonIconPrimaryColorBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ButtonIconPrimaryColorBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Margin="{TemplateBinding Margin}"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="FocusVisualStyle">
            <Setter.Value>
                <Style>
                    <Setter Property="Control.Template">
                        <Setter.Value>
                            <ControlTemplate>
                                <Rectangle Margin="0"
                                           Stroke="{StaticResource FocusButtonBrushColor}"
                                           StrokeThickness="2" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                            To="LightGray"
                                            Duration="0:0:0.2" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                            To="{StaticResource ButtonIconPrimaryColor}"
                                            Duration="0:0:0.2" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <!--#endregion-->

    <!--#region ComboBox-->
    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Margin" Value="4" />
        <Setter Property="Foreground" Value="{StaticResource TextButtonBrushColor}" />
        <Setter Property="Padding" Value="4" />
    </Style>
    <!--#endregion-->

    <!--#region CheckBox-->
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Margin" Value="4" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <!--  endregion  -->

    <!--#region DockPanel-->
    <Style TargetType="{x:Type DockPanel}" x:Key="headerDockPanelIconSection">
        <Setter Property="Background" Value="#808080" />
    </Style>
    <!--#endregion-->

    <!--#region Image Disable Style in Button-->
    <Style TargetType="{x:Type Image}" x:Key="diasbleImageInButton">
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <!--#endregion-->

    <!--#region ListView Style-->
    <Style TargetType="{x:Type ListView}">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#424242" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="False" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListView}">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False"
                                      Background="Transparent"
                                      Padding="0"
                                      Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource BackgroundTextBoxDisableBrushColor}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{x:Type ListViewItem}" TargetType="{x:Type ListViewItem}">
        <Setter Property="SnapsToDevicePixels" Value="true" />
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border Name="Border"
                            Padding="0,2,2,0"
                            SnapsToDevicePixels="true">
                        <GridViewRowPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="true">
                            <Setter TargetName="Border" Property="Background" Value="Black" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="false">
                            <Setter Property="Foreground" Value="DarkBlue" />
                        </Trigger>

                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <PriorityBinding>
                                    <Binding Path="OverduePayments" />
                                    <Binding FallbackValue="False" />
                                </PriorityBinding>
                            </DataTrigger.Binding>
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource ListViewBrushColor}" />
                        </DataTrigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!--#endregion-->

    <!--#region GridViewColumnHeaderGripper-->
    <Style x:Key="GridViewColumnHeaderGripper" TargetType="Thumb">
        <Setter Property="Width" Value="18" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <LinearGradientBrush.GradientStops>
                        <GradientStopCollection>
                            <GradientStop Color="Black" Offset="0.0" />
                            <GradientStop Color="Black" Offset="1.0" />
                        </GradientStopCollection>
                    </LinearGradientBrush.GradientStops>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                        <Rectangle HorizontalAlignment="Center"
                                   Width="1"
                                   Fill="{TemplateBinding Background}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="0" />
                    <GradientStop Color="White" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>
    <!--#endregion-->

    <!--#region ResizeUserControlGripper-->
    <Style x:Key="ResizeUserControlGripper" TargetType="{x:Type Thumb}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid x:Name="resizeVisual"
                          DockPanel.Dock="Right"
                          VerticalAlignment="Bottom">
                        <Line X1="6"
                              Y1="18"
                              X2="18"
                              Y2="6"
                              Stroke="DarkGray"
                              StrokeThickness="1.5" />
                        <!--  smallest/right|bottom most  -->
                        <Line X1="10"
                              Y1="18"
                              X2="18"
                              Y2="10"
                              Stroke="DarkGray"
                              StrokeThickness="1.5" />
                        <Line X1="14"
                              Y1="18"
                              X2="18"
                              Y2="14"
                              Stroke="DarkGray"
                              StrokeThickness="1.5" />
                        <!--  longers/left|top most  -->
                        <Grid.Style>
                            <Style TargetType="{x:Type Grid}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Cursor" Value="SizeNWSE" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!--#endregion-->

    <!--#region ViewBox-->
    <Style TargetType="{x:Type Viewbox}" x:Key="ViewBox4Icon">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
    </Style>
    <!--#endregion-->

    <!--#region ButtonContent-->
    <Style TargetType="{x:Type Path}" x:Key="ContentButtonPathStyle">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Stretch" Value="Fill" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />

        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=IsMouseOver}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Path.Fill).(SolidColorBrush.Color)">
                                <LinearColorKeyFrame KeyTime="0:0:0.2" Value="{StaticResource ButtonIconPrimaryColor}" />
                            </ColorAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Path.Fill).(SolidColorBrush.Color)">
                                <LinearColorKeyFrame KeyTime="0:0:0.2" Value="{StaticResource ButtonIconColor}" />
                            </ColorAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <!--#endregion-->

