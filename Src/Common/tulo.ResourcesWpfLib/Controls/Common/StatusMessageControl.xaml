<UserControl x:Class="tulo.ResourcesWpfLib.Controls.Common.StatusMessageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.ResourcesWpfLib.Controls.Common"
             mc:Ignorable="d"
             d:DesignHeight="70"
             d:DesignWidth="2000">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Visibility="{Binding HasMessage, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
        <Grid.RowDefinitions>
            <RowDefinition Height="8" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Background="{StaticResource WarningBrushColor}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Viewbox Grid.Column="0"
                     Width="30"
                     Height="30"
                     Margin="10,2,0,2">
                <Path Data="{StaticResource WarningWideIconSVG}"
                      Fill="Black"
                      Stretch="Fill"
                      Height="20"
                      Width="20" />
            </Viewbox>
            <TextBlock Grid.Column="1"
                       Foreground="Black"
                       Text="{Binding Message}"
                       TextWrapping="Wrap"
                       TextTrimming="None"
                       TextAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="16"
                       Margin="10,0,0,0"
                       HorizontalAlignment="Stretch" />
        </Grid>
    </Grid>
</UserControl>
