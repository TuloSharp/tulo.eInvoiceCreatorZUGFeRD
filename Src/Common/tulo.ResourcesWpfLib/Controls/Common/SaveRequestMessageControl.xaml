<UserControl x:Class="tulo.ResourcesWpfLib.Controls.Common.SaveRequestMessageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.ResourcesWpfLib.Controls.Common"
             mc:Ignorable="d"
             d:DesignHeight="80"
             d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Visibility="{Binding IsSaveRequestMessageVisible, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
        <Grid.RowDefinitions>
            <RowDefinition Height="8" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="9" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="1">
            <StackPanel Background="{StaticResource WarningBrushColor}">
                <DockPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="9" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="10" />
                        </Grid.ColumnDefinitions>
                        <Viewbox Grid.Column="1"
                                 Width="30"
                                 Height="30"
                                 Margin="0,2,0,2">
                            <Path Data="{StaticResource WarningWideIconSVG}"
                                  Fill="Black"
                                  HorizontalAlignment="Left"
                                  Stretch="Fill"
                                  Height="40"
                                  Width="40" />
                        </Viewbox>
                        <Label Name="SaveRequestMessage"
                               Grid.Column="3"
                               Padding="0,8,0,0"
                               Foreground="Black"
                               FontSize="16"
                               Margin="0,1,0,0"
                               Content="{Binding LabelSaveRequestMessage}"
                               HorizontalAlignment="Left" />

                        <Button Name="yesButton"
                                Grid.Column="5"
                                HorizontalAlignment="Center"
                                KeyboardNavigation.AcceptsReturn="False"
                                BorderBrush="Transparent"
                                Foreground="Transparent"
                                IsEnabled="{Binding IsEnableToSaveData}"
                                ToolTip="{Binding ToolTipYesButtonSaveRequestMessage}"
                                Command="{Binding SubmitCommand}">
                            <Grid>
                                <Path Style="{StaticResource ContentButtonPathStyle}"
                                      Data="{StaticResource DoneIconSVG}"
                                      Fill="{StaticResource ButtonBrushIconColor}" />
                                <!--<TextBlock Text="Z"
                                           Width="12"
                                           TextAlignment="Center"
                                           VerticalAlignment="Bottom"
                                           HorizontalAlignment="Right"
                                           Background="{StaticResource MainBrushColor}"
                                           Foreground="{StaticResource ButtonBrushIconColor}" />
                                <AccessText Text="_Yes"
                                            FontSize="8"
                                            Foreground="Transparent"
                                            Background="Transparent" />-->
                            </Grid>
                        </Button>

                        <Button Name="noButton"
                                Grid.Column="7"
                                HorizontalAlignment="Center"
                                KeyboardNavigation.AcceptsReturn="False"
                                BorderBrush="Transparent"
                                Foreground="Transparent"
                                ToolTip="{Binding ToolTipNoButtonSaveRequestMessage}"
                                Command="{Binding CloseCommand}">
                            <Grid>
                                <Path Style="{StaticResource ContentButtonPathStyle}"
                                      Data="{StaticResource CloseIconSVG}"
                                      Fill="{StaticResource ButtonBrushIconColor}" />
                                <!--<TextBlock Text="Z"
                    Width="12"
                    TextAlignment="Center"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    Background="{StaticResource MainBrushColor}"
                    Foreground="{StaticResource ButtonBrushIconColor}" />
         <AccessText Text="_No"
                     FontSize="8"
                     Foreground="Transparent"
                     Background="Transparent" />-->
                            </Grid>
                        </Button>

                        <Button Name="returnButton"
                                Grid.Column="9"
                                HorizontalAlignment="Center"
                                KeyboardNavigation.AcceptsReturn="False"
                                BorderBrush="Transparent"
                                Foreground="Transparent"
                                ToolTip="{Binding ToolTipReturnButtonSaveRequestMessage}"
                                Command="{Binding HideCommand}">
                            <Grid>
                                <Path Style="{StaticResource ContentButtonPathStyle}"
                                      Data="{StaticResource ArrowBackIconSVG}"
                                      Fill="{StaticResource ButtonBrushIconColor}" />
                                <!--<TextBlock Text="Z"
           Width="12"
           TextAlignment="Center"
           VerticalAlignment="Bottom"
           HorizontalAlignment="Right"
           Background="{StaticResource MainBrushColor}"
           Foreground="{StaticResource ButtonBrushIconColor}" />
<AccessText Text="R_Return"
            FontSize="8"
            Foreground="Transparent"
            Background="Transparent" />-->
                            </Grid>
                        </Button>

                    </Grid>
                </DockPanel>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2" Background="Transparent" />
    </Grid>
</UserControl>
