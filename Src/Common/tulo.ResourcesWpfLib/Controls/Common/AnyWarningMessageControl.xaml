<UserControl x:Class="tulo.ResourcesWpfLib.Controls.Common.AnyWarningMessageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:tulo.ResourcesWpfLib.Controls.Common"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="8" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="1" 
                   Background="{StaticResource WarningBrushColor}">
            <DockPanel>
                <Viewbox Width="30" 
                         Height="30" 
                         Margin="10 2 0 2">
                    <Path Data="{StaticResource WarningWideIconSVG}" 
                          Fill="Black" 
                          Stretch="Fill" 
                          Height="20" 
                          Width="20" />
                </Viewbox>
                <TextBlock Foreground="Black" 
                           Text="{Binding AnyWarningMessage}" 
                           VerticalAlignment="Center" 
                           FontSize="16"  
                           Margin="9 0 0 0" 
                           HorizontalAlignment="Left" />
            </DockPanel>
        </WrapPanel>
    </Grid>
</UserControl>
