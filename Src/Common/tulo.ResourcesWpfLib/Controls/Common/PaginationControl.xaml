<UserControl x:Class="tulo.ResourcesWpfLib.Controls.Common.PaginationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.ResourcesWpfLib.Controls.Common"
             xmlns:commoncontrols="clr-namespace:tulo.ResourcesWpfLib.Controls.Common"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:extensions="clr-namespace:tulo.ResourcesWpfLib.Extensions"
             xmlns:converters="clr-namespace:tulo.ResourcesWpfLib.Converters"
             xmlns:extended="clr-namespace:tulo.ResourcesWpfLib.Utilities"
             xmlns:enums="clr-namespace:tulo.ResourcesWpfLib.Enums"
             mc:Ignorable="d"
             d:DesignHeight="80"
             d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:EnumConverter x:Key="EnumConverter" />
            <converters:InputErrorToBorderBrushConverter x:Key="InputErrorToBorderBrushConverter" />
            <converters:IntToStringConverter x:Key="IntToStringConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="10" />
                <RowDefinition Height="40" />
                <RowDefinition Height="10" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="1"
                  Background="{StaticResource PanelBrushColor}"
                  Margin="6,0,6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="0" /> 
                    <!--  Text boxes has an inherited 4px padding on the left side  -->
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="10" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Text="{Binding DatasetsQuantity, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource IntToStringConverter}}"
                         Width="50"
                         Height="24"
                         IsEnabled="False"
                         HorizontalContentAlignment="Right"
                         VerticalContentAlignment="Center" />
                <Label Grid.Row="0"
                       Grid.Column="3"
                       Content="Data sets"
                       HorizontalContentAlignment="Center"
                       VerticalContentAlignment="Center" />

                <ComboBox Grid.Row="0"
                          Grid.Column="5"
                          HorizontalAlignment="Left"
                          Template="{StaticResource ComboBoxCustomized}"
                          Validation.ErrorTemplate="{x:Null}"
                          Name="comboBoxFilterType"
                          Height="26"
                          Margin="1,0,0,0"
                          Padding="8,5,0,0"
                          Width="100"
                          IsEnabled="True"
                          IsSynchronizedWithCurrentItem="True"
                          SelectedIndex="{Binding SelectedIndexNrDataRecordsPerPage}"
                          SelectedItem="{Binding NrDataRecordsPerPageType, Converter={StaticResource EnumConverter}, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding Source={extensions:EnumBindingSource enums:NrDataRecordsPerPageType}}"
                          extended:ExtendedFocusByEnter.ExtendedByEnterKey="True">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                    <behaviors:Interaction.Behaviors>
                        <extended:ComboBoxSelectionChangedBehavior Command="{Binding LoadEntityCommand}" CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                    </behaviors:Interaction.Behaviors>
                </ComboBox>


                <Label Grid.Row="0"
                       Grid.Column="7"
                       Content="Number of records per page"
                       HorizontalContentAlignment="Center"
                       VerticalContentAlignment="Center" />

                <Button Name="FirstPageButton"
                        Grid.Column="10"
                        Grid.Row="0"
                        IsEnabled="{Binding IsFirstPageButtonEnabled}"
                        Width="24"
                        Height="24"
                        ToolTip="erste Seite"
                        Command="{Binding LoadEntityCommand}"
                        CommandParameter="first">
                    <Grid>
                        <Path Style="{StaticResource ContentButtonPathStyle}"
                              Data="{StaticResource FirstPageIconSVG}"
                              Fill="{StaticResource ButtonBrushIconColor}"
                              Width="18"
                              Height="18" />
                    </Grid>
                </Button>
                <Button Name="PreviousPageButton"
                        Grid.Column="12"
                        Grid.Row="0"
                        IsEnabled="{Binding IsPreviousPageButtonEnabled}"
                        Width="24"
                        Height="24"
                        ToolTip="vorherige Seite"
                        Command="{Binding LoadEntityCommand}"
                        CommandParameter="previous">
                    <Grid>
                        <Path Style="{StaticResource ContentButtonPathStyle}"
                              Data="{StaticResource PreviousPageIconSVG}"
                              Fill="{StaticResource ButtonBrushIconColor}"
                              Width="18"
                              Height="18" />
                    </Grid>
                </Button>

                <TextBox Grid.Row="0"
                         Grid.Column="14"
                         Text="{Binding PageXofY, UpdateSourceTrigger=PropertyChanged}"
                         Width="130"
                         Height="24"
                         IsEnabled="False"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center" />

                <Button Name="NextPageButton"
                        Grid.Column="16"
                        Grid.Row="0"
                        IsEnabled="{Binding IsNextPageButtonEnabled}"
                        Width="24"
                        Height="24"
                        ToolTip="nächste Seite"
                        Command="{Binding LoadEntityCommand}"
                        CommandParameter="next">
                    <Grid>
                        <Path Style="{StaticResource ContentButtonPathStyle}"
                              Data="{StaticResource NextpageIconSVG}"
                              Fill="{StaticResource ButtonBrushIconColor}"
                              Width="18"
                              Height="18" />
                    </Grid>
                </Button>

                <Button Name="LastPageButton"
                        Grid.Column="18"
                        Grid.Row="0"
                        IsEnabled="{Binding IsLastPageButtonEnabled}"
                        Width="24"
                        Height="24"
                        ToolTip="letzte Seite"
                        Command="{Binding LoadEntityCommand}"
                        CommandParameter="last">
                    <Grid>
                        <Path Style="{StaticResource ContentButtonPathStyle}"
                              Data="{StaticResource LastPageIconSVG}"
                              Fill="{StaticResource ButtonBrushIconColor}"
                              Width="18"
                              Height="18" />
                    </Grid>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

