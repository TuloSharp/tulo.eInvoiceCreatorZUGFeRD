<UserControl x:Class="tulo.ResourcesWpfLib.Controls.Common.InfoToggleButtonControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:extended="clr-namespace:tulo.ResourcesWpfLib.Utilities"
             mc:Ignorable="d"
             d:DesignHeight="50"
             d:DesignWidth="50">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <ToggleButton IsChecked="{Binding IsToggleButtonChecked}"
                      IsEnabled="{Binding IsToggleButtonShowMesaggeEnabled}" 
                      Command="{Binding OpenSyntaxTestHelpCommand}"
                      CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}"
                      HorizontalAlignment="Left"
                      ToolTip="Infos zum Feld"
                      KeyboardNavigation.AcceptsReturn="False"
                      IsTabStop="False"
                      extended:ExtendedFocusByEnter.ExtendedByEnterKey="True">
            <Grid>
                <Viewbox Width="20"
                         Height="20"
                         Margin="0,1,0,0">
                    <Path Data="{StaticResource InfoIconSVG}"
                          Style="{StaticResource ContentToggleButtonPathStyle}"
                          Fill="{StaticResource ButtonBrushIconColor}"
                          Stretch="Fill" />
                </Viewbox>

                <TextBlock Text="I"
                           Width="8"
                           TextAlignment="Center"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Right"
                           Visibility="{Binding IsAltSchortcutKeyPressed, Converter={StaticResource BooleanToVisibilityConverter}}"
                           Background="{StaticResource MainBrushColor}"
                           Foreground="{StaticResource ButtonBrushIconColor}" />

                <AccessText Text="_Info"
                            FontSize="8"
                            Foreground="Transparent"
                            Background="Transparent" />
            </Grid>
        </ToggleButton> 
    </Grid>
</UserControl>
