<UserControl x:Class="tulo.ResourcesWpfLib.Controls.LiveLogs.LiveLogsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.ResourcesWpfLib.Controls.LiveLogs"
             xmlns:converters="clr-namespace:tulo.ResourcesWpfLib.Converters"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:custombehaviors="clr-namespace:tulo.ResourcesWpfLib.Utilities"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:LogLevelToBrushConverter x:Key="LogLevelToBrushConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <ListBox Grid.Row="1"
         x:Name="LogList"
         Height="120"
         ItemsSource="{Binding Messages}"
         Background="LightGreen"
         BorderThickness="0"
         FontFamily="Consolas"
         Visibility="{Binding IsLiveLogsActive, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
         FontSize="12">

        <ListBox.ItemTemplate>
            <DataTemplate>

                <StackPanel Orientation="Horizontal">
                    <!--  Timestamp  -->
                    <TextBlock Text="{Binding Timestamp}"
                           Foreground="DarkOrange"
                           Margin="0,0,8,0" />
                    <!--  Level  -->
                    <TextBlock Text="{Binding Level}"
                           Foreground="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}"
                           FontWeight="Bold"
                           Margin="0,0,8,0" />
                    <!--  Message  -->
                    <TextBlock Text="{Binding Message}" Foreground="DarkSlateBlue" />
                </StackPanel>
            </DataTemplate>
        </ListBox.ItemTemplate>
        <behaviors:Interaction.Behaviors>
            <custombehaviors:AutoScrollBehavior />
        </behaviors:Interaction.Behaviors>
    </ListBox>
</UserControl>
