<UserControl x:Class="tulo.ResourcesWpfLib.Controls.AppSettings.AppSettingsDbControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:tulo.ResourcesWpfLib.Controls.AppSettings"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0"
            Grid.Column="0"
            Content="Database:"
            VerticalAlignment="Center"
            HorizontalAlignment="Left" />

        <Label Grid.Row="1"
            Grid.Column="1"
            Content="DB Server Type:"
            VerticalAlignment="Center" />

        <Label Grid.Row="1"
            Grid.Column="2"
            HorizontalAlignment="Left"
            BorderThickness="0"
            Style="{StaticResource DisplayLabel}"
            Content="{Binding DbServerType}" />

        <Label Grid.Row="2"
            Grid.Column="1"
            Content="Connection String:"
            VerticalAlignment="Center" />

        <Label Grid.Row="2"
            Grid.Column="2"
            HorizontalAlignment="Left"
            
            BorderThickness="0"
            Style="{StaticResource DisplayLabel}"
            Content="{Binding ConnectionString}" />
    </Grid>
</UserControl>
