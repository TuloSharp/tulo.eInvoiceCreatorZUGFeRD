<UserControl x:Class="tulo.ResourcesWpfLib.Controls.AppSettings.AppSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:tulo.ResourcesWpfLib.Controls.AppSettings"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <GroupBox Height="auto"
                Margin="3,0,3,4"
                Padding="0"
                BorderBrush="{StaticResource GroupBoxBrushColor}"
                BorderThickness="1">
            <GroupBox.Header>
                <TextBlock Margin="2"
                         FontStyle="Oblique"
                         Text="AppSettings" />
            </GroupBox.Header>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="auto" />

                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0"
                         Content="App version:"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Left"/>

                    <Label Grid.Column="1"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
             
                         BorderThickness="0"
                         Style="{StaticResource DisplayLabel}"
                         Content="{Binding AppVersionNumber}" />

                </Grid>

                <local:AppSettingsDbControl Grid.Row="1" />
                <local:AppSettingsSerilogControl Grid.Row="2" />
            </Grid>

        </GroupBox>

    </Grid>
</UserControl>
